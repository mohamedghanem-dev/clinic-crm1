{
  "name": "clinic-crm",
  "version": "2.0.0",
  "description": "نظام إدارة العيادات المتكامل",
  "main": "electron.js",
  "author": "Clinic CRM",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.clinic.crm",
    "productName": "عيادتي CRM",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "electron.js",
      "sw.js",
      "manifest.json",
      "icon.png",
      "icon-192.png",
      "icon-512.png",
      "icon_b64.js"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "installerLanguages": ["ar"],
      "language": "1025"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.medical"
    }
  }
}
